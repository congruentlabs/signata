{
  "name": "@signata/verifier",
  "version": "0.0.0",
  "description": "Browser-safe verifier for verifiable credentials (SD-JWT VC, W3C JWT-VC)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sd-jwt/core": "^0.10.0",
    "did-resolver": "^4.1.0",
    "jose": "^5.9.0",
    "web-did-resolver": "^2.0.27"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/congruentlabs/signata.git",
    "directory": "packages/verifier"
  }
}
